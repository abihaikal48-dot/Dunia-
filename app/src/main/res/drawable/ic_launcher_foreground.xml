<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Glowing backdrop pulse at the center of the world -->
    <path
        android:pathData="M54,54m-30,0a30,30 0 1,1 60,0a30,30 0 1,1 -60,0"
        android:fillColor="#153B82F6" />

    <path
        android:pathData="M54,54m-22,0a22,22 0 1,1 44,0a22,22 0 1,1 -44,0"
        android:fillColor="#0B4F46E5" />

    <!-- 1. The Globe of Shared Future (DUNIA) -->
    <!-- Outer circle boundary -->
    <path
        android:pathData="M54,54m-20,0a20,20 0 1,1 40,0a20,20 0 1,1 -40,0"
        android:strokeColor="#1E293B"
        android:strokeWidth="1.5"
        android:fillColor="#00000000" />

    <!-- Subtle elegant latitude lines -->
    <path
        android:pathData="M37,45 Q54,50 71,45"
        android:strokeColor="#334155"
        android:strokeWidth="1"
        android:fillColor="#00000000" />
    <path
        android:pathData="M37,63 Q54,58 71,63"
        android:strokeColor="#334155"
        android:strokeWidth="1"
        android:fillColor="#00000000" />
    
    <!-- Longitude meridian line -->
    <path
        android:pathData="M54,34 Q46,54 54,74"
        android:strokeColor="#334155"
        android:strokeWidth="1"
        android:fillColor="#00000000" />
    <path
        android:pathData="M54,34 Q62,54 54,74"
        android:strokeColor="#334155"
        android:strokeWidth="1"
        android:fillColor="#00000000" />

    <!-- 2. Haikal's Orbit (Sky Blue - Sleek swoosh from bottom-left to top-right) -->
    <path
        android:pathData="M24,78 C30,64 42,40 64,32 C78,28 88,38 84,52 C81,64 68,76 48,82 C34,86 20,82 24,78 Z"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="24"
                android:startY="78"
                android:endX="84"
                android:endY="32"
                android:type="linear">
                <item android:offset="0.0" android:color="#0284C7" />
                <item android:offset="1.0" android:color="#38BDF8" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 3. Ummu's Orbit (Chic Pink - Symmetrical crossing swoosh) -->
    <path
        android:pathData="M84,78 C78,64 66,40 44,32 C30,28 20,38 24,52 C27,64 40,76 60,82 C74,86 88,82 84,78 Z"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="84"
                android:startY="78"
                android:endX="24"
                android:endY="32"
                android:type="linear">
                <item android:offset="0.0" android:color="#DB2777" />
                <item android:offset="1.0" android:color="#F472B6" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 4. Glowing Golden Central Union Star at the intersection of their lives -->
    <!-- Large vertical radiant diamonds -->
    <path
        android:pathData="M54,42 L55.5,52.5 L66,54 L55.5,55.5 L54,66 L52.5,55.5 L42,54 L52.5,52.5 Z"
        android:fillColor="#FFFFFF" />
    <path
        android:pathData="M54,45 L55.1,52.9 L63,54 L55.1,55.1 L54,63 L52.9,55.1 L45,54 L52.9,52.9 Z"
        android:fillColor="#FBBF24" />

    <!-- 5. Floating sparkles of their future roadmap goals -->
    <!-- Top-Left diamond -->
    <path
        android:pathData="M34,30 L35,33 L38,34 L35,35 L34,38 L33,35 L30,34 L33,33 Z"
        android:fillColor="#FBBF24" />
    <!-- Top-Right diamond -->
    <path
        android:pathData="M74,30 L75,33 L78,34 L75,35 L74,38 L73,35 L70,34 L73,33 Z"
        android:fillColor="#38BDF8" />
    <!-- Center-Bottom sparkle -->
    <path
        android:pathData="M54,78 L54.7,80.7 L57.4,81.4 L54.7,82.1 L54,84.8 L53.3,82.1 L50.6,81.4 L53.3,80.7 Z"
        android:fillColor="#F472B6" />
